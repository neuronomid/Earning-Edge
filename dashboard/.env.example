# ─── Backend URL ──────────────────────────────────────────────────────────────
# The URL of the Earning Edge Docker backend (FastAPI on port 8000).
# Used server-side only (API routes). Do NOT prefix with NEXT_PUBLIC_.
EARNING_EDGE_API_BASE_URL=http://127.0.0.1:8000

# The same URL but exposed to the browser for direct fetch calls (dashboard snapshot, etc.)
NEXT_PUBLIC_EARNING_EDGE_API_BASE_URL=http://127.0.0.1:8000

# ─── Market Data Provider ─────────────────────────────────────────────────────
# Choose: "backend" (proxies through the Docker backend → yfinance/Alpaca)
#         "mock"    (simulated prices that change every 5 seconds)
MARKET_DATA_PROVIDER=backend

# ─── Display mode label (client-readable, no secrets) ─────────────────────────
# Shows in the Live Market Data Test UI. Safe to prefix with NEXT_PUBLIC_.
# Values: "REAL_TIME" | "DELAYED" | "MOCK"
NEXT_PUBLIC_MARKET_DATA_MODE=DELAYED

# ─── Alpaca (optional — stored in backend database per-user, not here) ────────
# Do NOT store Alpaca keys here. They are saved per-user via Settings → API Keys.
# The backend retrieves them from the encrypted user record.

# ─── Other providers (future — server-side only, never NEXT_PUBLIC_) ──────────
# TRADIER_TOKEN=
# POLYGON_API_KEY=
# ALPACA_API_KEY=
# ALPACA_SECRET_KEY=

# ─── Next.js ──────────────────────────────────────────────────────────────────
# No additional variables required for development.
