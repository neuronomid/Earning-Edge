# Application
APP_ENV=development
APP_LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8000

# Postgres (used in Phase 1+)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=earning_edge
POSTGRES_USER=earning_edge
POSTGRES_PASSWORD=earning_edge_dev

# Redis (used in Phase 2+)
REDIS_HOST=redis
REDIS_PORT=6379

# Encryption master key (Fernet, base64-urlsafe 32 bytes) — generated in Phase 1
APP_ENCRYPTION_KEY=

# Telegram (Phase 2). Create a bot via @BotFather and paste the token here.
TELEGRAM_BOT_TOKEN=
# Optional Telegram tuning
# Long-polling is the default in dev. To switch to webhook, set TELEGRAM_USE_WEBHOOK=true
# and provide TELEGRAM_WEBHOOK_URL + TELEGRAM_WEBHOOK_SECRET.
TELEGRAM_USE_WEBHOOK=false
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=

# LLM model IDs (Phase 7) — concrete OpenRouter model IDs. Thinking mode for
# the heavy model is enabled via the `reasoning` parameter inside the router;
# do not append `-thinking` to the model ID (OpenRouter rejects it as invalid).
MARKET_ANALYSIS_MODEL=anthropic/claude-opus-4.7
LIGHTWEIGHT_MODEL=google/gemini-3.1-pro-preview

# Finviz / browser automation (Phase 4)
FINVIZ_HEADLESS=false
FINVIZ_TIMEOUT_MS=30000

# Backup earnings calendar (Phase 4)
FINNHUB_API_KEY=

# QA intraday drift harness
QA_USER_CHAT_ID=qa_intraday
QA_ACCOUNT_SIZE=10000
QA_RISK_PROFILE=Balanced
QA_TIMEZONE_LABEL=ET
QA_TIMEZONE_IANA=America/Toronto
QA_BROKER=Wealthsimple
QA_STRATEGY_PERMISSION=long_and_short
QA_MAX_CONTRACTS=3
QA_OPENROUTER_API_KEY=
QA_ALPACA_API_KEY=
QA_ALPACA_API_SECRET=
QA_ALPHA_VANTAGE_API_KEY=
