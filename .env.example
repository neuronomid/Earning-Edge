# Application
APP_ENV=development
APP_LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8000

# Postgres (used in Phase 1+)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=earning_edge
POSTGRES_USER=earning_edge
POSTGRES_PASSWORD=earning_edge_dev

# Redis (used in Phase 2+)
REDIS_HOST=redis
REDIS_PORT=6379

# Encryption master key (Fernet, base64-urlsafe 32 bytes) — generated in Phase 1
APP_ENCRYPTION_KEY=

# Telegram (Phase 2)
TELEGRAM_BOT_TOKEN=

# LLM model aliases (Phase 7) — resolved to concrete OpenRouter IDs at runtime
MARKET_ANALYSIS_MODEL=claude-opus-4.7-thinking
LIGHTWEIGHT_MODEL=gemini-3.1-flash
